# Node.js dependencies
node_modules/
npm-debug.log*
npm-error.log*
package-lock.json
yarn.lock
yarn-error.log

# Temporary HLS files - these are generated at runtime
tmp/
*.ts
*.m3u8
!**/*.md
!**/*.js

# Environment and secrets - never commit passwords!
.env
.env.local
.env.*.local
*.env

# Logs
logs/
*.log

# Runtime data
pids/
*.pid
*.seed
*.pid.lock

# Directory for instrumented libs generated by jscoverage/JSCover
lib-cov/

# Coverage directory used by tools like istanbul
coverage/
.nyc_output/

# IDE and editor files
.vscode/
.idea/
*.swp
*.swo
*~
.DS_Store
*.sublime-*
*.sublime-workspace

# Windows specific
Thumbs.db
ehthumbs.db
Desktop.ini
$RECYCLE.BIN/

# Linux/Raspberry Pi specific
*.pid
*.lock
*.sock

# FFmpeg temp files
ffmpeg2pass*
ffmpeg_temp/
temp/

# OS generated files
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db

# Project specific - ignore local config if you create one
config.local.js
*.local.js

# Backup files
*.bak
*.backup
*.old

# Test outputs
test_output/
test-results/
.dyad/
